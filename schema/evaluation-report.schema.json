{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/evaluation-report.schema.json",
  "title": "Project Evolution Quality Drift Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "report_id",
    "generated_at_utc",
    "project",
    "versions",
    "inputs",
    "semantic_frame",
    "selected_archetype",
    "selected_domain",
    "stage_evaluations",
    "drift_comparisons",
    "problem_matches",
    "baseline_recommendation",
    "corrective_prompt",
    "uncertainties",
    "final_assessment"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "report_id": {
      "type": "string",
      "pattern": "^REPORT-[A-Z0-9._-]+$"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "name"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version_id",
          "label",
          "role"
        ],
        "properties": {
          "version_id": {
            "type": "string",
            "pattern": "^VER-[A-Z0-9._-]+$"
          },
          "label": {
            "type": "string"
          },
          "role": {
            "enum": [
              "baseline_candidate",
              "target",
              "historical",
              "comparison",
              "unknown"
            ]
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "version_id",
          "input_type",
          "name",
          "availability"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9._-]+$"
          },
          "version_id": {
            "type": "string",
            "pattern": "^VER-[A-Z0-9._-]+$"
          },
          "input_type": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result"
            ]
          },
          "name": {
            "type": "string"
          },
          "availability": {
            "enum": [
              "available",
              "partial",
              "missing",
              "reference_only"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "semantic_frame": {
      "$ref": "#/$defs/semanticFrame"
    },
    "selected_archetype": {
      "$ref": "#/$defs/classification"
    },
    "selected_domain": {
      "$ref": "#/$defs/classification"
    },
    "stage_evaluations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stageEvaluation"
      }
    },
    "drift_comparisons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/driftComparison"
      }
    },
    "problem_matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/problemMatch"
      }
    },
    "baseline_recommendation": {
      "$ref": "#/$defs/baselineRecommendation"
    },
    "corrective_prompt": {
      "$ref": "#/$defs/correctivePrompt"
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "final_assessment": {
      "$ref": "#/$defs/finalAssessment"
    }
  },
  "$defs": {
    "semanticStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "evidence_status",
        "confidence"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "evidence_status": {
          "enum": [
            "confirmed",
            "partial",
            "contradicted",
            "unconfirmed"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "support_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "semanticFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_request",
        "intent",
        "goal",
        "objectives",
        "ados_profile_expectations",
        "glossary_terms_used"
      ],
      "properties": {
        "user_request": {
          "$ref": "#/$defs/semanticStatement"
        },
        "intent": {
          "$ref": "#/$defs/semanticStatement"
        },
        "goal": {
          "$ref": "#/$defs/semanticStatement"
        },
        "objectives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/semanticStatement"
          }
        },
        "ados_profile_expectations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/semanticStatement"
          }
        },
        "glossary_terms_used": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "term_id",
              "evaluation_purpose"
            ],
            "properties": {
              "term_id": {
                "type": "string",
                "pattern": "^TERM-[A-Z0-9-]+$"
              },
              "evaluation_purpose": {
                "type": "string",
                "minLength": 5
              },
              "interpretation_note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "confidence",
        "rationale",
        "alternatives"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(ARCH|DOMAIN)-[A-Z0-9-]+$"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "reason_not_selected"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^(ARCH|DOMAIN)-[A-Z0-9-]+$"
              },
              "reason_not_selected": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "coordinateEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coordinate_id",
        "metric_id",
        "score",
        "confidence",
        "evidence_status",
        "rationale",
        "support_refs"
      ],
      "properties": {
        "coordinate_id": {
          "type": "string",
          "pattern": "^COORD-[A-Z0-9-]+$"
        },
        "metric_id": {
          "type": "string",
          "pattern": "^MET-[A-Z0-9-]+$"
        },
        "score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 10
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence_status": {
          "enum": [
            "confirmed",
            "partial",
            "contradicted",
            "unconfirmed"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 5
        },
        "support_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stageEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_evaluation_id",
        "version_id",
        "input_type",
        "source_ids",
        "coordinates",
        "total_score",
        "strengths",
        "limitations",
        "uncertainties"
      ],
      "properties": {
        "stage_evaluation_id": {
          "type": "string",
          "pattern": "^STAGE-[A-Z0-9._-]+$"
        },
        "version_id": {
          "type": "string",
          "pattern": "^VER-[A-Z0-9._-]+$"
        },
        "input_type": {
          "enum": [
            "build_package",
            "agent_work",
            "build_result"
          ]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9._-]+$"
          }
        },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/coordinateEvaluation"
          }
        },
        "total_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "total_score_method": {
          "type": "string"
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "coordinateDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coordinate_id",
        "from_score",
        "to_score",
        "delta",
        "direction",
        "confidence",
        "rationale"
      ],
      "properties": {
        "coordinate_id": {
          "type": "string",
          "pattern": "^COORD-[A-Z0-9-]+$"
        },
        "from_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 10
        },
        "to_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 10
        },
        "delta": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -10,
          "maximum": 10
        },
        "direction": {
          "enum": [
            "improvement",
            "degradation",
            "mixed",
            "unchanged",
            "unconfirmed"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "driftFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "governing_term_ids",
        "affected_coordinate_ids",
        "observation",
        "direction",
        "severity",
        "confidence",
        "consequence",
        "risk"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^DRIFT-[A-Z0-9._-]+$"
        },
        "governing_term_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^TERM-[A-Z0-9-]+$"
          }
        },
        "affected_coordinate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^COORD-[A-Z0-9-]+$"
          }
        },
        "observation": {
          "type": "string",
          "minLength": 10
        },
        "direction": {
          "enum": [
            "improvement",
            "degradation",
            "mixed",
            "unchanged",
            "unconfirmed"
          ]
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "consequence": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "support_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "driftComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison_id",
        "from_version_id",
        "to_version_id",
        "comparison_type",
        "coordinate_deltas",
        "drift_findings",
        "conclusion"
      ],
      "properties": {
        "comparison_id": {
          "type": "string",
          "pattern": "^CMP-[A-Z0-9._-]+$"
        },
        "from_version_id": {
          "type": "string",
          "pattern": "^VER-[A-Z0-9._-]+$"
        },
        "to_version_id": {
          "type": "string",
          "pattern": "^VER-[A-Z0-9._-]+$"
        },
        "comparison_type": {
          "enum": [
            "baseline_to_build_package",
            "build_package_to_agent_work",
            "agent_work_to_build_result",
            "build_package_to_build_result",
            "result_to_result"
          ]
        },
        "coordinate_deltas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/coordinateDelta"
          }
        },
        "drift_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/driftFinding"
          }
        },
        "conclusion": {
          "type": "string"
        }
      }
    },
    "problemMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_id",
        "version_ids",
        "confidence",
        "observed_signals",
        "consequence",
        "risk",
        "corrective_actions"
      ],
      "properties": {
        "problem_id": {
          "type": "string",
          "pattern": "^PROB-[A-Z0-9-]+$"
        },
        "version_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^VER-[A-Z0-9._-]+$"
          }
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "observed_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "consequence": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "corrective_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "baselineRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_version_id",
        "confidence",
        "rationale",
        "rejected_alternatives"
      ],
      "properties": {
        "selected_version_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^VER-[A-Z0-9._-]+$"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "rejected_alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "version_id",
              "reason"
            ],
            "properties": {
              "version_id": {
                "type": "string",
                "pattern": "^VER-[A-Z0-9._-]+$"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "correctivePrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "based_on_problem_ids",
        "goal_and_scope_protection",
        "expected_result"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "based_on_problem_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^PROB-[A-Z0-9-]+$"
          }
        },
        "goal_and_scope_protection": {
          "type": "string"
        },
        "expected_result": {
          "type": "string"
        }
      }
    },
    "finalAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "rationale",
        "coordinate_summary",
        "limitations"
      ],
      "properties": {
        "value": {
          "enum": [
            "improvement",
            "mixed",
            "degradation",
            "unchanged",
            "insufficient_evidence"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "coordinate_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "improved",
            "degraded",
            "unchanged",
            "unconfirmed"
          ],
          "properties": {
            "improved": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^COORD-[A-Z0-9-]+$"
              }
            },
            "degraded": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^COORD-[A-Z0-9-]+$"
              }
            },
            "unchanged": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^COORD-[A-Z0-9-]+$"
              }
            },
            "unconfirmed": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^COORD-[A-Z0-9-]+$"
              }
            }
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
