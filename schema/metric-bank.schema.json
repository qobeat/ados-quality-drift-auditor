{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/metric-bank.schema.json",
  "title": "Goal-Attractor Coordinate and Metric Bank",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "bank_id",
    "geometry",
    "metrics",
    "summary_policy"
  ],
  "properties": {
    "$schema": {
      "const": "../schema/metric-bank.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "bank_id": {
      "const": "METRIC-BANK-QDA-V0.2"
    },
    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_model_term_id",
        "coordinate_term_id",
        "metric_term_id",
        "coordinates"
      ],
      "properties": {
        "semantic_model_term_id": {
          "const": "TERM-GOAL-ATTRACTOR-GEOMETRY"
        },
        "coordinate_term_id": {
          "const": "TERM-COORDINATE-DIMENSION"
        },
        "metric_term_id": {
          "const": "TERM-EVALUATION-METRIC"
        },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/coordinate"
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "summary_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_score_optional",
        "total_score_method",
        "default_score_scale",
        "confidence_values",
        "evidence_status_values"
      ],
      "properties": {
        "total_score_optional": {
          "type": "boolean"
        },
        "total_score_method": {
          "type": "string",
          "minLength": 20
        },
        "default_score_scale": {
          "const": "0_to_10"
        },
        "confidence_values": {
          "const": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence_status_values": {
          "const": [
            "confirmed",
            "partial",
            "contradicted",
            "unconfirmed"
          ]
        }
      }
    }
  },
  "$defs": {
    "scale": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "polarity",
        "target"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "polarity": {
          "enum": [
            "higher_is_better",
            "lower_is_better",
            "target_range",
            "categorical"
          ]
        },
        "target": {
          "type": "string"
        }
      }
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coordinate_id",
        "name",
        "definition",
        "glossary_term_ids",
        "applies_to",
        "scale",
        "evidence_guidance",
        "default_metric_ids"
      ],
      "properties": {
        "coordinate_id": {
          "type": "string",
          "pattern": "^COORD-[A-Z0-9-]+$"
        },
        "name": {
          "type": "string"
        },
        "definition": {
          "type": "string",
          "minLength": 20
        },
        "glossary_term_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^TERM-[A-Z0-9-]+$"
          }
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result",
              "cross_version"
            ]
          }
        },
        "scale": {
          "$ref": "#/$defs/scale"
        },
        "evidence_guidance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "default_metric_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^MET-[A-Z0-9-]+$"
          }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "name",
        "coordinate_id",
        "glossary_term_ids",
        "applies_to",
        "question",
        "scale",
        "required_interpretation",
        "guardrails"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "pattern": "^MET-[A-Z0-9-]+$"
        },
        "name": {
          "type": "string"
        },
        "coordinate_id": {
          "type": "string",
          "pattern": "^COORD-[A-Z0-9-]+$"
        },
        "glossary_term_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^TERM-[A-Z0-9-]+$"
          }
        },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result",
              "cross_version"
            ]
          }
        },
        "question": {
          "type": "string",
          "minLength": 10
        },
        "scale": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "anchors"
          ],
          "properties": {
            "type": {
              "const": "0_to_10_optional"
            },
            "anchors": {
              "type": "object",
              "minProperties": 5,
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "required_interpretation": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "guardrails": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
