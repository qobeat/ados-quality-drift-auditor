{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/problem-bank.schema.json",
  "title": "Quality Problem Pattern Bank Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "bank_id",
    "version",
    "severity_order",
    "matching_policy",
    "patterns"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "bank_id": {
      "type": "string",
      "pattern": "^PROBLEM-BANK-[A-Z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "severity_order": {
      "const": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "matching_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_basis",
        "prohibition",
        "confidence_scale",
        "reporting"
      ],
      "properties": {
        "minimum_basis": {
          "type": "string"
        },
        "prohibition": {
          "type": "string"
        },
        "confidence_scale": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "low",
            "medium",
            "high"
          ],
          "properties": {
            "low": {
              "type": "string"
            },
            "medium": {
              "type": "string"
            },
            "high": {
              "type": "string"
            }
          }
        },
        "reporting": {
          "type": "string"
        }
      }
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/problem"
      }
    }
  },
  "$defs": {
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_id",
        "name",
        "risk_level",
        "applicable_stages",
        "applicable_archetype_ids",
        "problem_statement",
        "pattern",
        "observable_signals",
        "visible_effects",
        "likely_causes",
        "consequences",
        "detection_methods",
        "corrective_actions",
        "preventive_controls",
        "required_evidence",
        "related_hard_gate_ids",
        "real_examples"
      ],
      "properties": {
        "problem_id": {
          "type": "string",
          "pattern": "^PROB-[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 3
        },
        "risk_level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "applicable_stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result"
            ]
          }
        },
        "applicable_archetype_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "const": "*"
              },
              {
                "type": "string",
                "pattern": "^ARCH-[A-Z0-9-]+$"
              }
            ]
          }
        },
        "problem_statement": {
          "type": "string",
          "minLength": 20
        },
        "pattern": {
          "type": "string",
          "minLength": 20
        },
        "observable_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "visible_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "likely_causes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "consequences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "detection_methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "corrective_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "preventive_controls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "related_hard_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^HG-[0-9]{3}$"
          }
        },
        "real_examples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "example_id",
              "project",
              "versions",
              "observation",
              "lesson"
            ],
            "properties": {
              "example_id": {
                "type": "string",
                "pattern": "^EX-[A-Z0-9-]+$"
              },
              "project": {
                "type": "string"
              },
              "versions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "observation": {
                "type": "string",
                "minLength": 20
              },
              "lesson": {
                "type": "string",
                "minLength": 10
              }
            }
          }
        }
      }
    }
  }
}
