{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/problem-bank.schema.json",
  "title": "Quality Drift Problem Pattern Bank",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "bank_id",
    "matching_policy",
    "patterns"
  ],
  "properties": {
    "$schema": {
      "const": "../schema/problem-bank.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "bank_id": {
      "const": "PROBLEM-BANK-QDA-V0.2"
    },
    "matching_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_basis",
        "confidence_values",
        "rule",
        "output"
      ],
      "properties": {
        "minimum_basis": {
          "type": "string",
          "minLength": 10
        },
        "confidence_values": {
          "const": [
            "high",
            "medium",
            "low"
          ]
        },
        "rule": {
          "type": "string",
          "minLength": 20
        },
        "output": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pattern"
      }
    }
  },
  "$defs": {
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "versions",
        "observation",
        "lesson"
      ],
      "properties": {
        "project": {
          "type": "string"
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "observation": {
          "type": "string",
          "minLength": 15
        },
        "lesson": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem_id",
        "name",
        "glossary_term_ids",
        "affected_input_types",
        "affected_coordinate_ids",
        "applicable_archetype_ids",
        "risk_level",
        "definition",
        "observable_signals",
        "exclusions",
        "visible_effects",
        "likely_causes",
        "consequences",
        "drift_risks",
        "how_to_confirm",
        "how_to_fix",
        "wrong_fix_patterns",
        "real_examples"
      ],
      "properties": {
        "problem_id": {
          "type": "string",
          "pattern": "^PROB-[A-Z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 3
        },
        "glossary_term_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^TERM-[A-Z0-9-]+$"
          }
        },
        "affected_input_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result"
            ]
          }
        },
        "affected_coordinate_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^COORD-[A-Z0-9-]+$"
          }
        },
        "applicable_archetype_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ARCH-[A-Z0-9-]+$"
          }
        },
        "risk_level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "definition": {
          "type": "string",
          "minLength": 20
        },
        "observable_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visible_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "likely_causes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "consequences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "drift_risks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "how_to_confirm": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "how_to_fix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "wrong_fix_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "real_examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/example"
          }
        }
      }
    }
  }
}
