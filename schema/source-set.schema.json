{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/source-set.schema.json",
  "title": "Project Evolution Source Set Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_set_id",
    "project",
    "versions",
    "artifacts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0"
    },
    "source_set_id": {
      "type": "string",
      "pattern": "^SOURCESET-[A-Z0-9._-]+$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "name",
        "description"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 2
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "declared_archetype_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^ARCH-[A-Z0-9-]+$"
        }
      }
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version_id",
          "label",
          "sequence",
          "status"
        ],
        "properties": {
          "version_id": {
            "type": "string",
            "pattern": "^VER-[A-Z0-9._-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "sequence": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "enum": [
              "baseline_candidate",
              "target",
              "historical",
              "unknown"
            ]
          },
          "parent_version_id": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^VER-[A-Z0-9._-]+$"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "version_id",
          "input_type",
          "name",
          "path",
          "media_type",
          "role",
          "availability",
          "evidence_scope"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9._-]+$"
          },
          "version_id": {
            "type": "string",
            "pattern": "^VER-[A-Z0-9._-]+$"
          },
          "input_type": {
            "enum": [
              "build_package",
              "agent_work",
              "build_result"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "media_type": {
            "type": "string",
            "minLength": 3
          },
          "role": {
            "type": "string",
            "minLength": 3
          },
          "availability": {
            "enum": [
              "available",
              "partial",
              "missing",
              "reference_only"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-f]{64}$"
          },
          "evidence_scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 2
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
