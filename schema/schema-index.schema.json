{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/schema-index.schema.json",
  "title": "Schema Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schemas",
    "bindings"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2.0"
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_id",
          "path",
          "sha256"
        ],
        "properties": {
          "schema_id": {
            "type": "string",
            "pattern": "^SCHEMA-[A-Z0-9-]+$"
          },
          "path": {
            "type": "string",
            "pattern": "^schema/.+\\.schema\\.json$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "instance",
          "schema"
        ],
        "properties": {
          "instance": {
            "type": "string",
            "minLength": 1
          },
          "schema": {
            "type": "string",
            "pattern": "^schema/.+\\.schema\\.json$"
          }
        }
      }
    }
  }
}
