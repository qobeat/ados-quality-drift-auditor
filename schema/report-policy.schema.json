{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/report-policy.schema.json",
  "title": "Evaluation Report Policy Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "policy_id",
    "version",
    "evidence_classes",
    "required_unconfirmed_phrase",
    "evidence_coverage",
    "verdict_rules",
    "baseline_selection",
    "proof_fixture_policy"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "policy_id": {
      "type": "string",
      "pattern": "^REPORT-POLICY-[A-Z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "evidence_classes": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "observed",
          "derived",
          "inference",
          "judgment",
          "unconfirmed"
        ]
      }
    },
    "required_unconfirmed_phrase": {
      "const": "I cannot confirm this."
    },
    "evidence_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula",
        "pass_minimum",
        "conditional_minimum",
        "below_conditional_verdict"
      ],
      "properties": {
        "formula": {
          "type": "string"
        },
        "pass_minimum": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "conditional_minimum": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "below_conditional_verdict": {
          "const": "INSUFFICIENT_EVIDENCE"
        }
      }
    },
    "verdict_rules": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verdict",
          "conditions"
        ],
        "properties": {
          "verdict": {
            "enum": [
              "PASS",
              "CONDITIONAL_PASS",
              "FAIL",
              "INSUFFICIENT_EVIDENCE"
            ]
          },
          "conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "baseline_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule",
        "required_checks",
        "hybrid_baseline_rule"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 20
        },
        "required_checks": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "hybrid_baseline_rule": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "proof_fixture_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule",
        "forbidden_inference",
        "simple_calculator_example"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 20
        },
        "forbidden_inference": {
          "type": "string",
          "minLength": 10
        },
        "simple_calculator_example": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  }
}
