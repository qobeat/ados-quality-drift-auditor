{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/report-policy.schema.json",
  "title": "Evaluation Report Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "policy_id",
    "semantic_authority",
    "required_glossary_retrieval",
    "evidence_policy",
    "scoring_policy",
    "drift_policy",
    "baseline_policy",
    "final_assessment_policy",
    "corrective_prompt_policy"
  ],
  "properties": {
    "$schema": {
      "const": "../schema/report-policy.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "policy_id": {
      "const": "REPORT-POLICY-QDA-V0.2"
    },
    "semantic_authority": {
      "const": "GLOSSARY.md"
    },
    "required_glossary_retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_groups",
        "report_requirement"
      ],
      "properties": {
        "minimum_groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^TERM-[A-Z0-9-]+$"
            }
          }
        },
        "report_requirement": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "evidence_policy": {
      "$ref": "#/$defs/rulesObject"
    },
    "scoring_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score_scale",
        "score_requires",
        "no_score_when",
        "total_score_optional",
        "rules"
      ],
      "properties": {
        "score_scale": {
          "const": "0_to_10_optional"
        },
        "score_requires": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "no_score_when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "total_score_optional": {
          "type": "boolean"
        },
        "rules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "drift_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direction_values",
        "severity_values",
        "required_elements",
        "comparison_types"
      ],
      "properties": {
        "direction_values": {
          "const": [
            "improvement",
            "degradation",
            "mixed",
            "unchanged",
            "unconfirmed"
          ]
        },
        "severity_values": {
          "const": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "required_elements": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "comparison_types": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "baseline_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_rule",
        "required_output",
        "component_reuse_note"
      ],
      "properties": {
        "selection_rule": {
          "type": "string",
          "minLength": 20
        },
        "required_output": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        },
        "component_reuse_note": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "final_assessment_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "values",
        "rules"
      ],
      "properties": {
        "values": {
          "const": [
            "improvement",
            "mixed",
            "degradation",
            "unchanged",
            "insufficient_evidence"
          ]
        },
        "rules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "corrective_prompt_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_elements",
        "rules"
      ],
      "properties": {
        "required_elements": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "rulesObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_values",
        "confidence_values",
        "unconfirmed_phrase",
        "rules"
      ],
      "properties": {
        "status_values": {
          "const": [
            "confirmed",
            "partial",
            "contradicted",
            "unconfirmed"
          ]
        },
        "confidence_values": {
          "const": [
            "high",
            "medium",
            "low"
          ]
        },
        "unconfirmed_phrase": {
          "const": "I cannot confirm this."
        },
        "rules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
