{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/skill.schema.json",
  "title": "Project Evolution Quality Auditor Skill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "skill_id",
    "name",
    "version",
    "goal",
    "objectives",
    "semantic_authority",
    "authority_load_order",
    "supported_input_types",
    "rag_retrieval_policy",
    "method",
    "guardrails",
    "required_report_sections",
    "output_schema"
  ],
  "properties": {
    "$schema": {
      "const": "../schema/skill.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "skill_id": {
      "const": "SKILL-PROJECT-EVOLUTION-QUALITY-AUDITOR"
    },
    "name": {
      "type": "string",
      "minLength": 5
    },
    "version": {
      "const": "0.2.0"
    },
    "goal": {
      "type": "string",
      "minLength": 50
    },
    "objectives": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 20
      }
    },
    "semantic_authority": {
      "const": "GLOSSARY.md"
    },
    "authority_load_order": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string"
      }
    },
    "supported_input_types": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/inputType"
      }
    },
    "rag_retrieval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_retrieval",
        "contextual_retrieval",
        "retrieval_output"
      ],
      "properties": {
        "first_retrieval": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "pattern": "^TERM-[A-Z0-9-]+$"
          }
        },
        "contextual_retrieval": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        },
        "retrieval_output": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_fields",
            "optional_fields"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "optional_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "method": {
      "type": "array",
      "minItems": 10,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "required_report_sections": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "output_schema": {
      "const": "schema/evaluation-report.schema.json"
    }
  },
  "$defs": {
    "inputType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_type",
        "glossary_term_id",
        "examples",
        "evaluation_focus"
      ],
      "properties": {
        "input_type": {
          "enum": [
            "build_package",
            "agent_work",
            "build_result"
          ]
        },
        "glossary_term_id": {
          "type": "string",
          "pattern": "^TERM-[A-Z0-9-]+$"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "evaluation_focus": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "name",
        "instruction",
        "output"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^STEP-[0-9]{2}$"
        },
        "name": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 20
        },
        "output": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
