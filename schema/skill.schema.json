{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/skill.schema.json",
  "title": "Project Evolution Quality Auditor Skill Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "skill_id",
    "version",
    "name",
    "goal",
    "supported_input_types",
    "authority_load_order",
    "procedure",
    "constraints",
    "references",
    "output_files"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "skill_id": {
      "const": "SKILL-PROJECT-EVOLUTION-QUALITY-AUDITOR"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 5
    },
    "goal": {
      "type": "string",
      "minLength": 30
    },
    "supported_input_types": {
      "const": [
        "build_package",
        "agent_work",
        "build_result"
      ]
    },
    "authority_load_order": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "procedure": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "name",
          "purpose",
          "required_outputs"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^STEP-[0-9]{2}$"
          },
          "name": {
            "type": "string"
          },
          "purpose": {
            "type": "string",
            "minLength": 10
          },
          "required_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archetype_bank",
        "metric_bank",
        "problem_bank",
        "report_policy",
        "source_schema",
        "claim_schema",
        "report_schema"
      ],
      "properties": {
        "archetype_bank": {
          "type": "string",
          "minLength": 1
        },
        "metric_bank": {
          "type": "string",
          "minLength": 1
        },
        "problem_bank": {
          "type": "string",
          "minLength": 1
        },
        "report_policy": {
          "type": "string",
          "minLength": 1
        },
        "source_schema": {
          "type": "string",
          "minLength": 1
        },
        "claim_schema": {
          "type": "string",
          "minLength": 1
        },
        "report_schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "output_files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_ledger",
        "evidence_ledger",
        "evaluation_report"
      ],
      "properties": {
        "claim_ledger": {
          "type": "string"
        },
        "evidence_ledger": {
          "type": "string"
        },
        "evaluation_report": {
          "type": "string"
        }
      }
    }
  }
}
