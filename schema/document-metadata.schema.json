{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/document-metadata.schema.json",
  "title": "ADOS Document Metadata Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "DOCUMENT_TYPE",
    "DOCUMENT_STATUS",
    "UPDATED_AT",
    "DOCUMENT_ROLE",
    "GOVERNANCE_AREA",
    "CONSUMERS",
    "WHEN_TO_USE",
    "HOW_TO_USE",
    "DOCUMENT_CONTENT"
  ],
  "properties": {
    "DOCUMENT_TYPE": {
      "type": "string",
      "minLength": 2
    },
    "DOCUMENT_STATUS": {
      "enum": [
        "draft",
        "candidate",
        "final",
        "superseded",
        "historical",
        "accepted"
      ]
    },
    "UPDATED_AT": {
      "type": "string",
      "format": "date"
    },
    "DOCUMENT_ROLE": {
      "type": "string",
      "minLength": 2
    },
    "GOVERNANCE_AREA": {
      "type": "string",
      "minLength": 2
    },
    "CONSUMERS": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "WHEN_TO_USE": {
      "type": "string",
      "pattern": "^Use (before|when|after|during|to) .+"
    },
    "HOW_TO_USE": {
      "type": "string",
      "minLength": 10
    },
    "DOCUMENT_CONTENT": {
      "type": "string",
      "minLength": 10
    },
    "DEFINED_FILES": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "SCHEMA_REF": {
      "type": "string"
    },
    "AUTHORITY_REF": {
      "type": "string"
    },
    "REPLACES": {
      "type": "string"
    },
    "SUPERSEDES": {
      "type": "string"
    },
    "NOTES": {
      "type": "string"
    }
  }
}
