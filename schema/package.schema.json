{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/package.schema.json",
  "title": "ADOS Quality Drift Auditor Package Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "package_name",
    "slug",
    "version",
    "artifact_name",
    "status",
    "goal",
    "objectives",
    "semantic_authority",
    "project_definition",
    "entrypoints",
    "source_methodology",
    "clean_room_design",
    "non_goals"
  ],
  "properties": {
    "$schema": {
      "const": "schema/package.schema.json"
    },
    "package_name": {
      "const": "ados-quality-drift-auditor"
    },
    "slug": {
      "const": "ados-quality-drift-auditor"
    },
    "version": {
      "const": "0.2.0"
    },
    "artifact_name": {
      "const": "ados-quality-drift-auditor-v0.2.zip"
    },
    "status": {
      "enum": [
        "prototype",
        "candidate",
        "final",
        "deprecated"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 50
    },
    "objectives": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 20
      }
    },
    "semantic_authority": {
      "const": "GLOSSARY.md"
    },
    "project_definition": {
      "const": "PDD.md"
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human",
        "agent",
        "skill",
        "archetypes",
        "domains",
        "metrics",
        "report_policy",
        "problems",
        "schemas",
        "outputs"
      ],
      "properties": {
        "human": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "archetypes": {
          "type": "string",
          "minLength": 1
        },
        "domains": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "string",
          "minLength": 1
        },
        "report_policy": {
          "type": "string",
          "minLength": 1
        },
        "problems": {
          "type": "string",
          "minLength": 1
        },
        "schemas": {
          "type": "string",
          "minLength": 1
        },
        "outputs": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_methodology": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "use"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "use": {
            "type": "string",
            "minLength": 20
          },
          "excluded": {
            "type": "string"
          },
          "adaptation": {
            "type": "string"
          }
        }
      }
    },
    "clean_room_design": {
      "const": true
    },
    "non_goals": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 15
      }
    }
  }
}
