{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/manifest.schema.json",
  "title": "Package Manifest Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_name",
    "package_version",
    "hash_policy",
    "folders",
    "files"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "package_name": {
      "const": "ados-quality-drift-auditor"
    },
    "package_version": {
      "const": "0.1.0"
    },
    "hash_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "manifest_self_hash",
        "external_artifact_hash"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "manifest_self_hash": {
          "const": "excluded_to_avoid_self_reference"
        },
        "external_artifact_hash": {
          "const": "computed_after_zip_creation"
        }
      }
    },
    "folders": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^[^/].*/$"
          },
          "role": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role",
          "size_bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 2
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    }
  }
}
