{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/adr-index.schema.json",
  "title": "ADR Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "records"
  ],
  "properties": {
    "$schema": {
      "const": "../schema/adr-index.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "adr_id",
          "title",
          "status",
          "path"
        ],
        "properties": {
          "adr_id": {
            "type": "string",
            "pattern": "^ADR-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 5
          },
          "status": {
            "enum": [
              "proposed",
              "accepted",
              "superseded",
              "historical"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^adr/adr-[0-9]{3}\\.md$"
          }
        }
      }
    }
  }
}
