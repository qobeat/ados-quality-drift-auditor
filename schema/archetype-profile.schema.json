{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/archetype-profile.schema.json",
  "title": "Project Archetype Profile Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "profile_id",
    "version",
    "name",
    "description",
    "selection",
    "stage_metric_weights",
    "common_axis_profile",
    "primary_risks",
    "mandatory_evidence",
    "applicable_problem_ids",
    "drift_dimensions",
    "proof_policy"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^ARCH-[A-Z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "positive_signals",
        "exclusion_signals",
        "minimum_confidence_for_primary",
        "fallback_profile_id"
      ],
      "properties": {
        "positive_signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exclusion_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "minimum_confidence_for_primary": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fallback_profile_id": {
          "const": "ARCH-GENERAL-ENGINEERED-ARTIFACT"
        }
      }
    },
    "stage_metric_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_package",
        "agent_work",
        "build_result"
      ],
      "properties": {
        "build_package": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metricWeight"
          }
        },
        "agent_work": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metricWeight"
          }
        },
        "build_result": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metricWeight"
          }
        }
      }
    },
    "common_axis_profile": {
      "const": "metrics/metric-bank.json#common_axes"
    },
    "primary_risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "mandatory_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_package",
        "agent_work",
        "build_result"
      ],
      "properties": {
        "build_package": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "agent_work": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "build_result": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "applicable_problem_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^PROB-[0-9]{3}$"
      }
    },
    "drift_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^DRIFT-[A-Z0-9-]+$"
      }
    },
    "proof_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bounded_claim_rule",
        "fixture_pass_is_release_pass",
        "require_final_artifact_origin"
      ],
      "properties": {
        "bounded_claim_rule": {
          "type": "string",
          "minLength": 10
        },
        "fixture_pass_is_release_pass": {
          "const": false
        },
        "require_final_artifact_origin": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "metricWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "weight"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "pattern": "^(BP|AW|BR)-[0-9]{3}$"
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    }
  }
}
